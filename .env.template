# DigiKey API Configuration
# Copy this file to .env and fill in your credentials
#
# Get credentials at: https://developer.digikey.com
# 1. Sign in with your My DigiKey account
# 2. Go to Apps -> Add sandbox app
# 3. Copy CLIENT_ID and CLIENT_SECRET

DIGIKEY_CLIENT_ID=
DIGIKEY_CLIENT_SECRET=

# true = sandbox (testing), false = production (real data)
DIGIKEY_USE_SANDBOX=true

# auto = mock when no credentials, true = always mock, false = never mock
DIGIKEY_MOCK_MODE=auto

# Cache TTL in seconds (default: 86400 = 24 hours)
DIGIKEY_CACHE_TTL=86400
